[
  {
    "id": "lat_pulldown",
    "nameZh": "高位下拉机",
    "nameEn": "Lat Pulldown Machine",
    "category": "cable",
    "targetMusclesZh": [
      "背阔肌"
    ],
    "secondaryMusclesZh": [
      "肱二头肌",
      "中背部",
      "斜方肌"
    ],
    "imageName": null,
    "descriptionZh": "高位下拉机是训练背阔肌的经典固定器械，通过调整握法和身体角度可以刺激背部不同区域。适合从初学者到高级训练者，是打造V形背部的核心动作。",
    "adjustmentsZh": [
      "调整座椅高度，使大腿固定垫刚好压住大腿上方。",
      "调整大腿固定垫位置，确保身体在拉动时不会向上移动。",
      "根据动作选择合适把手：宽握把手练背阔肌宽度，窄握把手练背阔肌下沿。",
      "选择合适重量，从轻重量开始热身。"
    ],
    "safetyTipsZh": [
      "不要将横杆拉到颈后，容易造成颈椎损伤。",
      "不要身体大幅后仰借力，减少下背部压力。",
      "不要猛拉猛放，保持动作控制。",
      "肩膀保持下沉，不要耸肩代偿。"
    ],
    "exerciseIds": [
      "wide_grip_lat_pulldown",
      "close_grip_lat_pulldown"
    ],
    "difficulty": "新手友好"
  },
